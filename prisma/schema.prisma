datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  DIRECAO
  DAF
  COMUNICACAO
  CAMPO
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  image        String?
  role         Role      @default(CAMPO)
  passwordHash      String?   // null = ainda não definiu senha própria
  mustResetPassword Boolean   @default(false)
  accessGaleria     Boolean?  // null = usa default do role
  accessManuais     Boolean?
  accessEstrategia  Boolean?
  accessFinancas    Boolean?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  uploads      FileLog[]
}

model FileLog {
  id            String    @id @default(cuid())
  googleDriveId String    @unique
  fileName      String
  fileType      String    // IMAGE | VIDEO | PDF | DOCX | XLSX
  mimeType      String
  category      String    // FOTOS_TERRENO | FINANCEIRO | ESTRATEGIA | PROCEDIMENTOS
  activityName  String?
  location      String?
  activityDate  DateTime?
  shareLink     String?
  uploadedById  String
  uploadedBy    User      @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime  @default(now())
}
