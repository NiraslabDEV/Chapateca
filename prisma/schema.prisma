datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  DIRECAO
  DAF
  COMUNICACAO
  CAMPO
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  image        String?
  role         Role      @default(CAMPO)
  passwordHash      String?   // null = ainda não definiu senha própria
  mustResetPassword Boolean   @default(false)
  accessGaleria     Boolean?  // null = usa default do role
  accessManuais     Boolean?
  accessEstrategia  Boolean?
  accessFinancas    Boolean?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  uploads      FileLog[]
  albums       Album[]
  folders      Folder[]
}

model Folder {
  id          String    @id @default(cuid())
  name        String
  category    String    // FINANCEIRO | MANUAIS | ESTRATEGIA
  parentId    String?
  parent      Folder?   @relation("SubFolders", fields: [parentId], references: [id])
  children    Folder[]  @relation("SubFolders")
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  files       FileLog[]
}

model Task {
  id        String    @id @default(cuid())
  fromEmail String
  toEmail   String
  title     String
  body      String?
  status    String    @default("pending") // pending | received | done
  readAt    DateTime?
  doneAt    DateTime?
  createdAt DateTime  @default(now())
}

// Audit log de acções importantes (deleções, etc.) — alimenta o feed do Dashboard.
model ActivityLog {
  id          String   @id @default(cuid())
  actorEmail  String
  actorName   String
  action      String   // 'album.delete' | 'photo.delete' | 'marketing.delete' | ...
  description String   // texto pronto para exibir: "apagou álbum Polana Caniço B (3 fotos)"
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model Album {
  id           String    @id @default(cuid())
  activityName String?
  location     String
  activityDate DateTime
  activityType String?
  participants Int?
  observations String?
  shareToken   String?   @unique
  uploadedById String
  uploadedBy   User      @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime  @default(now())
  photos       FileLog[]
}

model FileLog {
  id            String    @id @default(cuid())
  googleDriveId String    @unique
  fileName      String
  fileType      String    // IMAGE | VIDEO | PDF | DOCX | XLSX
  mimeType      String
  fileSize      Int?      // bytes
  category      String    // FOTOS_TERRENO | FINANCEIRO | ESTRATEGIA | PROCEDIMENTOS
  activityName  String?
  location      String?   // para FINANCEIRO: docType (orcamento, relatorio, etc.)
  activityDate  DateTime?
  shareLink     String?
  albumId       String?
  album         Album?    @relation(fields: [albumId], references: [id])
  folderId      String?
  folder        Folder?   @relation(fields: [folderId], references: [id])
  uploadedById  String
  uploadedBy    User      @relation(fields: [uploadedById], references: [id])
  createdAt     DateTime  @default(now())
}
